APP_ENV=development
APP_LOG_LEVEL=INFO
PAPERWEAVE_CONFIG_PATH=configs/base.yaml
PAPERWEAVE_DATA_DIR=data
PAPERWEAVE_LOG_DIR=logs
PAPERWEAVE_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

LLM_PROVIDER=gemini
LLM_MODEL=gemini-2.0-flash
LLM_BASE_URL=https://generativelanguage.googleapis.com

EMBEDDING_PROVIDER=ollama
EMBEDDING_MODEL=nomic-embed-text
EMBEDDING_BASE_URL=http://127.0.0.1:11434
EMBEDDING_DIMENSIONS=768

JUDGE_PROVIDER=gemini
JUDGE_MODEL=gemini-2.0-flash
JUDGE_BASE_URL=https://generativelanguage.googleapis.com
JUDGE_API_KEY=
JUDGE_TIMEOUT_SECONDS=300
HF_TOKEN=

OPENAI_API_KEY=
GOOGLE_API_KEY=
GEMINI_API_KEY=

TIGERGRAPH_HOST=http://localhost
TIGERGRAPH_RESTPP_PORT=9000
TIGERGRAPH_GSQL_PORT=14240
TIGERGRAPH_USERNAME=tigergraph
TIGERGRAPH_PASSWORD=tigergraph
TIGERGRAPH_GRAPH_NAME=PaperWeave
TIGERGRAPH_URL=
TIGERGRAPH_API_KEY=

GRAPHRAG_API_BASE=http://localhost:8000
GRAPHRAG_TOP_K=5
GRAPHRAG_NUM_HOPS=2
GRAPHRAG_COMMUNITY_LEVEL=2

FRONTEND_API_BASE=http://localhost:8008
BERTSCORE_BACKEND=evaluate
BERTSCORE_DEVICE=cpu
